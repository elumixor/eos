default_platform(:ios)

PROJECT = "App/App.xcodeproj"
SCHEME = "PureType"
APP_IDENTIFIER = "app.puretype"

platform :ios do
  desc "Build and upload a new TestFlight build"
  lane :beta do
    # App Store Connect API key — required for both build-number lookup and upload.
    # Locally: set APP_STORE_CONNECT_API_KEY_PATH to a .p8 file on disk.
    # CI: provide APP_STORE_CONNECT_API_KEY_CONTENT (base64-encoded .p8) instead.
    key_args = { key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
                 issuer_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ISSUER_ID"),
                 in_house: false }
    if ENV["APP_STORE_CONNECT_API_KEY_PATH"]
      key_args[:key_filepath] = ENV["APP_STORE_CONNECT_API_KEY_PATH"]
    else
      key_args[:key_content] = ENV.fetch("APP_STORE_CONNECT_API_KEY_CONTENT")
      key_args[:is_key_content_base64] = false
    end
    api_key = app_store_connect_api_key(**key_args)

    next_build = latest_testflight_build_number(
      app_identifier: APP_IDENTIFIER,
      api_key: api_key,
      initial_build_number: 0
    ) + 1

    increment_build_number(
      xcodeproj: "App/App.xcodeproj",
      build_number: next_build
    )

    # Regenerate the App Store provisioning profile to include the current
    # distribution cert. force:true also forces a re-fetch when the local
    # state is stale, which CI always is.
    sigh(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      force: true
    )
    profile_name = lane_context[SharedValues::SIGH_NAME]

    # Manual signing for the archive step. Automatic signing in CI tries to
    # provision new certs (hits the Apple-side cert cap) and looks for a
    # Development profile that sigh never creates. Pinning to the profile
    # sigh just generated avoids both problems.
    team_id = sh("/usr/libexec/PlistBuddy -c 'Print :TeamIdentifier:0' " \
                 "/dev/stdin <<< \"$(security cms -D -i " \
                 "#{lane_context[SharedValues::SIGH_PROFILE_PATH]})\"", log: false).strip

    xcargs = [
      "CODE_SIGN_STYLE=Manual",
      "DEVELOPMENT_TEAM=#{team_id}",
      "PROVISIONING_PROFILE_SPECIFIER='#{profile_name}'",
      "CODE_SIGN_IDENTITY='Apple Distribution'",
    ]

    build_app(
      project: PROJECT,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      output_name: "App.ipa",
      clean: true,
      xcargs: xcargs.join(" "),
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        provisioningProfiles: { APP_IDENTIFIER => profile_name },
      }
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      skip_waiting_for_build_processing: true,
      ipa: "build/App.ipa"
    )
  end
end
