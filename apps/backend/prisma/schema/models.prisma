model User {
  id        String   @id @default(cuid())
  // Email is null for anonymous users created via /auth/anonymous.
  // On Google/Apple sign-in we populate this field (or merge into an
  // existing row), so `email IS NULL` doubles as the anonymous marker.
  email     String?  @unique
  name      String?
  projects  Project[]
  tasks     Task[]
  createdAt DateTime @default(now())
}

model Project {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  avatarType String   @default("auto") // auto | emoji | image
  emoji      String?
  image      String? // base64 data URL
  hue        Int? // 0-360 override for the generated avatar
  hidden     Boolean  @default(false)
  capitalization String @default("sentence") // sentence | lower | capitalized | upper
  order      Int      @default(0)
  parents    ProjectParent[] @relation("ChildToParents")
  children   ProjectParent[] @relation("ParentToChildren")
  tasks      Task[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  @@unique([userId, name])
  @@index([userId])
  @@index([userId, updatedAt])
}

// DAG: a project can have any number of parents (and children).
// onDelete: Cascade so removing a project tidies its edges.
model ProjectParent {
  childId  String
  parentId String
  child    Project @relation("ChildToParents", fields: [childId], references: [id], onDelete: Cascade)
  parent   Project @relation("ParentToChildren", fields: [parentId], references: [id], onDelete: Cascade)

  @@id([childId, parentId])
  @@index([parentId])
}

model Task {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  text        String
  completed   Boolean   @default(false)
  order       Int       @default(0)
  // Which fixed bucket the task lives in: "today" | "week" | "later".
  // "overdue" is purely derived (today/week tasks whose scheduledAt period
  // has passed and that are still incomplete) — never written.
  bucket      String    @default("later")
  // Stamped whenever bucket is set to "today" or "week". Used to decide
  // whether such a task should appear in the Overdue display bucket.
  scheduledAt DateTime?
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId   String?
  startTime   DateTime?
  duration    Int? // minutes
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([userId])
  @@index([userId, updatedAt])
}
